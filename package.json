{
  "name": "slidesmith",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Slidesmith — the AI-assisted editor for refining AI-generated HTML presentations.",
  "scripts": {
    "build:editor": "vite build --config vite.editor.config.ts",
    "dev": "npm run build:editor && vite",
    "build": "npm run build:editor && tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
