# Copy this file to `.env` and fill in your key. `.env` is gitignored.
# Loaded into process.env by vite.config.ts for the dev API (npm run dev).
# Restart `npm run dev` after editing — the handlers read env at startup.

# --- AI keys ----------------------------------------------------------------
# Deck generation works with EITHER provider; AI edits use OpenAI. With no key,
# both flows fall back to a deterministic mock so the app still works.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Generation mode --------------------------------------------------------
# multi (default) = structured plan→foundation→slides pipeline; output is bounded
#   per call (slides chunked, server-assembled), so it can't truncate on big decks.
# single = ONE high-effort "sample recipe" call → most hand-tuned per-slide design
#   (like sample_deck), but the whole deck must fit in one ≤32K-token response, so it
#   can truncate on large decks (then auto-falls back to multi, then mock).
# HTML_PPT_GEN_MODE=multi                    # multi | single
# HTML_PPT_SINGLE_MAX_TOKENS=32000          # single-mode only; raise (needs Opus 64k beta) for larger decks

# --- Generation provider ----------------------------------------------------
# Default: prefer Anthropic (Opus) and auto-fall back
# to OpenAI if the Anthropic call fails (e.g. empty balance). Set explicitly to
# flip the preference order; the other key (if present) stays the fallback.
# HTML_PPT_GEN_PROVIDER=openai            # anthropic | openai

# --- Generation model -------------------------------------------------------
# Anthropic: pinned to Opus by default (quality lever for the editorial pipeline).
# HTML_PPT_ANTHROPIC_MODEL=claude-opus-4-8
# OpenAI fallback model (used when the Anthropic call fails). Must be an exact
# model ID your account can call. Newer reasoning models bill reasoning tokens
# against the output budget; the OpenAI path clamps max_output_tokens to ~32K.
# HTML_PPT_GEN_OPENAI_MODEL=gpt-5.5

# --- Web research (PLAN pass) -----------------------------------------------
# The plan pass uses the provider's live web-search tool to source real stats /
# brand colors. Default on. OpenAI tool type + Anthropic max searches:
# HTML_PPT_WEB_SEARCH=0                    # disable web research
# HTML_PPT_WEB_SEARCH_MAX=6               # Anthropic max_uses per plan call
# HTML_PPT_OPENAI_WEBSEARCH_TOOL=web_search   # or web_search_preview

# --- QA / self-check pass (optional) ----------------------------------------
# auto = run the LLM repair only when the zero-token deckLint() finds an issue
# always = LLM QA on every deck (~2x output cost) · off = no LLM QA
# HTML_PPT_QA_MODE=auto

# --- Per-pass token / timeout limits (optional) -----------------------------
# HTML_PPT_PLAN_MAX_TOKENS=8000             # pass 1 outline
# HTML_PPT_FOUNDATION_MAX_TOKENS=32000      # pass 2 css/js/three
# HTML_PPT_SLIDES_MAX_TOKENS=16000          # pass 3 per section
# HTML_PPT_QA_MAX_TOKENS=16000              # pass 4 repair
# HTML_PPT_GEN_MAX_TOKENS=32000             # single-call fallback
# HTML_PPT_GEN_TIMEOUT=300                  # seconds (per call)

# --- Web image search (edit mode) -------------------------------------------
# "Find & paste a real photo" prefers a dedicated stock provider — direct image
# URLs in ~1s, far faster/more reliable than asking a web-search model to guess
# URLs. Set EITHER (Unsplash tried first, then Pexels). Free tiers exist.
# Falls back to the OpenAI web-search model when neither is set.
# UNSPLASH_ACCESS_KEY=xxxxxxxx              # https://unsplash.com/developers
# PEXELS_API_KEY=xxxxxxxx                   # https://www.pexels.com/api/
# HTML_PPT_STOCK_TIMEOUT=10                 # seconds per stock API call

# --- 3D scene regeneration (edit mode) --------------------------------------
# "Reimagine 3D background" authors a brand-new three_scene.js (uses the same
# generation provider/model as deck generation above).
# HTML_PPT_SCENE_MAX_TOKENS=20000

# --- Other (optional) -------------------------------------------------------
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# HTML_PPT_AI_MOCK=1                         # force mock mode even with a key set
# NOTE: token COST shown after generation is an ESTIMATE from a static rate table
# in shared/pricing.ts — update those rates to match your actual billing.
